% complex
\makeatletter % imaginary part
\renewcommand{\Im}{
	{%
		\futurelet\@let@token\@Im
	}%
}
\newcommand{\@Im}{
	\ifx\@let@token(
	\operatorname{\mathrm{Im}}
	\else
	\operatorname{\mathrm{Im}}\,
	\fi
}
\makeatother

\makeatletter % real part
\renewcommand{\Re}{
	\mathop{
		\futurelet\@let@token\@Re
	}
}
\newcommand{\@Re}{
	\ifx\@let@token(
	\operatorname{\mathrm{Re}}
	\else
	\operatorname{\mathrm{Re}}\,
	\fi
}
\makeatother


