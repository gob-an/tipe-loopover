% standard sets
\renewcommand{\P}{\mathds P}
\newcommand{\N}{\mathds N}
\newcommand{\Z}{\mathds Z}
\newcommand{\Q}{\mathds Q}
\newcommand{\R}{\mathds R}
\newcommand{\C}{\mathds C}
\newcommand{\F}[1]{\mathds F_{#1}}
\newcommand{\K}{\mathds K}

% standard letters
\newcommand{\eps}{\varepsilon} % epsilon
\newcommand{\vphi}{\varphi} % phi
\newcommand{\perm}{\mathfrak{S}} % symetric group
\newcommand{\esp}{\mathds E} % esperance


\NewDocumentCommand{\cv}{ o o }{  % limit
	\ensuremath{
		\IfNoValueTF{#1}{
			\IfNoValueTF{#2}{\rightarrow}{\xrightarrow[#2]{}}
		}{
			\IfNoValueTF{#2}{\xrightarrow[#1]{} }{ \xrightarrow[#2]{#1} }
		}
	}
}


% linear algebra
\makeatletter
\NewDocumentCommand{\Vect}{o} { % Vect
	\mathrm{Vect}
	\IfValueT{#1}{_{#1}}
	\@ifnextchar({}{\,}
}
\makeatother
\DeclareMathOperator{\rg}{rg} % rank
\DeclareMathOperator{\Sp}{Sp} % spectrum
\DeclareMathOperator{\Diag}{Diag}
\newcommand{\scal}[2]{\left\langle #1, #2\right\rangle} % scalar product
\DeclareMathOperator{\tr}{tr} % trace



\NewDocumentCommand{\Co}{o g g}{ % C^k class
	\mathcal C%
	\IfValueT{#1}{^{#1}}%
	\IfValueT{#2}{\left(#2
		\IfValueT{#3}{,\,#3}\right)}
}


